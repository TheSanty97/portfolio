---
import "../styles/global.css";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Mi Portafolio</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta
      name="description"
      content="Portafolio de Santiago Pérez - Ingeniero de Software."
    />
    <meta
      property="og:title"
      content="Portafolio de desarrollo de Santiago Pérez"
    />
    <meta
      property="og:description"
      content="Portafolio de Santiago Pérez - Ingeniero de Software."
    />
    <meta
      property="og:image"
      content="https://sapedev.com/og-image.png"
    />
    <meta property="og:url" content="https://sapedev.com" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_ES" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@thesanty97" />
    <meta name="twitter:creator" content="@thesanty97" />
    <meta
      name="twitter:title"
      content="Portafolio de desarrollo de Santiago Pérez"
    />
  </head>
  <body class="flex flex-col min-h-screen galaxy-bg">
    <Header />
    <main class="flex-grow">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style>
  html {
    scroll-behavior: smooth;
    scroll-padding-top: 5rem;
  }

  :global(.nav-link.active) {
    background-color: #1d4ed8;
    box-shadow: 0 0 0 2px rgba(96, 165, 250, 0.6);
  }

  body.galaxy-bg {
    position: relative;
    overflow-y: auto;
    min-height: 100vh;
    background-color: #07071a;
  }

  /* Malla de degradado animada (mesh gradient) */
  body.galaxy-bg::before {
    content: "";
    position: fixed;
    inset: 0;
    z-index: -2;
    background-image:
      radial-gradient(at 22% 28%, rgba(59, 130, 246, 0.40), transparent 45%),
      radial-gradient(at 78% 18%, rgba(147, 51, 234, 0.38), transparent 45%),
      radial-gradient(at 15% 78%, rgba(79, 70, 229, 0.38), transparent 45%),
      radial-gradient(at 85% 72%, rgba(56, 189, 248, 0.28), transparent 45%),
      radial-gradient(at 50% 50%, rgba(124, 58, 237, 0.30), transparent 50%);
    background-size: 180% 180%;
    filter: blur(60px);
    animation: mesh-move 18s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes mesh-move {
    0% {
      background-position: 0% 50%;
    }
    25% {
      background-position: 50% 100%;
    }
    50% {
      background-position: 100% 50%;
    }
    75% {
      background-position: 50% 0%;
    }
    100% {
      background-position: 0% 50%;
    }
  }

  /* Estrellas sutiles encima de la malla */
  body.galaxy-bg::after {
    content: "";
    position: fixed;
    inset: 0;
    z-index: -1;
    background-image:
      radial-gradient(1.5px 1.5px at 12% 18%, rgba(255, 255, 255, 0.7), transparent 50%),
      radial-gradient(1px 1px at 28% 42%, rgba(255, 255, 255, 0.5), transparent 50%),
      radial-gradient(1px 1px at 45% 12%, rgba(255, 255, 255, 0.6), transparent 50%),
      radial-gradient(1.5px 1.5px at 62% 32%, rgba(255, 255, 255, 0.5), transparent 50%),
      radial-gradient(1px 1px at 78% 58%, rgba(255, 255, 255, 0.6), transparent 50%),
      radial-gradient(1.5px 1.5px at 88% 22%, rgba(255, 255, 255, 0.5), transparent 50%),
      radial-gradient(1px 1px at 35% 78%, rgba(255, 255, 255, 0.5), transparent 50%),
      radial-gradient(1px 1px at 68% 85%, rgba(255, 255, 255, 0.4), transparent 50%);
    background-repeat: no-repeat;
    animation: twinkle 6s ease-in-out infinite;
    opacity: 0.5;
    pointer-events: none;
  }

  @keyframes twinkle {
    0%,
    100% {
      opacity: 0.35;
    }
    50% {
      opacity: 0.6;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    body.galaxy-bg::before,
    body.galaxy-bg::after {
      animation: none;
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const navLinks =
      document.querySelectorAll<HTMLAnchorElement>(".nav-link");
    const sections = document.querySelectorAll<HTMLElement>("section[id]");

    const setActive = (id: string) => {
      navLinks.forEach((link) =>
        link.classList.toggle(
          "active",
          link.getAttribute("href") === `#${id}`
        )
      );
    };

    // Marca activa la sección cuyo centro está en el viewport
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) setActive(entry.target.id);
        });
      },
      { rootMargin: "-45% 0px -45% 0px", threshold: 0 }
    );

    sections.forEach((section) => observer.observe(section));
  });
</script>

